# peak-load .env  —  copy to .env and fill in real values.
# All four API keys are optional: any unset key falls back to a
# synthetic data generator so a fresh clone can run end-to-end.
# For real trading signals you'll want all four populated.

# Region preset: ercot | nyiso | pjm | caiso  (defaults to ercot)
ENERGY_REGION=ercot

# EIA Open Data — electricity load + renewables
# https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# NOAA CDO — historical weather observations
# https://www.ncdc.noaa.gov/cdo-web/token
NOAA_TOKEN=

# OpenWeather — short-term forecast (One Call 3.0)
# https://openweathermap.org/api/one-call-3
OPENWEATHER_API_KEY=

# Kalshi REST credentials — same as the other bots in this stack
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_ENV=prod   # prod | demo

# ── Modeling knobs (sane defaults — override only when needed) ──────
# FORECAST_HORIZON_DAYS=1
# HISTORY_DAYS=730
# TEST_SIZE_DAYS=90
# TARGET_COLUMN=daily_peak_load_mw   # or net_peak_load_mw

# ── Threshold grid override (CSV of MW values, optional) ────────────
# THRESHOLD_GRID_MW=66000,67500,69000,70500,72000,73500,75000,76500,78000

# ── Signal gates ────────────────────────────────────────────────────
# MIN_EDGE=0.10
# MIN_VOLUME=50
# MIN_OPEN_INTEREST=50
# MAX_SPREAD_CENTS=8

# Disable to fail loudly when any data source is unreachable.
# USE_SYNTHETIC_WHEN_MISSING=true
