# Natural Gas Price bot — copy to .env and fill in real values.
#
# This bot targets Kalshi's KXNATGASD daily series (Henry Hub spot,
# Pyth-settled at 5pm EDT). Real Kalshi only — there is no demo path.

# ── Kalshi REST credentials (required for live signals) ─────────────
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# ── EIA Open Data — Henry Hub spot, storage, production
# https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# ── NOAA CDO — historical national weather for HDD/CDD aggregate
# https://www.ncdc.noaa.gov/cdo-web/token
NOAA_TOKEN=

# ── OpenWeather — next-day national-weighted forecast
# https://openweathermap.org/api/one-call-3
OPENWEATHER_API_KEY=

# ── Modeling knobs (defaults are reasonable — override only if needed)
# FORECAST_HORIZON_DAYS=1
# HISTORY_DAYS=1095        # 3 years of daily Henry Hub data
# TEST_SIZE_DAYS=120
# TARGET_COLUMN=natgas_henry_hub_usd_mmbtu

# ── Threshold grid override (CSV of $/MMBTU values, optional) ───────
# THRESHOLD_GRID_USD=2.50,2.75,3.00,3.25,3.50

# ── Signal gates ────────────────────────────────────────────────────
# MIN_EDGE=0.05
# MIN_VOLUME=25
# MIN_OPEN_INTEREST=25
# MAX_SPREAD_CENTS=10

# ── Sim risk caps ───────────────────────────────────────────────────
# BET_SIZE_CENTS=100
# MAX_OPEN_POSITIONS=1
# MAX_TOTAL_EXPOSURE_CENTS=200
# MAX_BETS_PER_DAY=5

# ── Hedge thresholds ────────────────────────────────────────────────
# HEDGE_ENABLED=true
# HEDGE_PROFIT_LOCK_CENTS=20
# HEDGE_STOP_LOSS_CENTS=15
# HEDGE_SIZE_FRACTION=1.0

# ── Synthetic data fallback for non-Kalshi sources ──────────────────
# Set to false to fail loudly if EIA / NOAA / OpenWeather is unreachable.
# USE_SYNTHETIC_WHEN_MISSING=true
